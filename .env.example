# Copy this file to .env and fill in your values
# Get your Gemini API key from: https://ai.google.dev/

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: Telegram alerts
# Create a bot via @BotFather on Telegram, then get your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: override scan schedule (24h format, IST)
PREMARKET_SCAN_HOUR=8
PREMARKET_SCAN_MINUTE=45
SCAN_HOUR=9
SCAN_MINUTE=15
MIDDAY_SCAN_HOUR=12
MIDDAY_SCAN_MINUTE=0
EOD_SCAN_HOUR=15
EOD_SCAN_MINUTE=30
NEXT_SESSION_SCAN_HOUR=16
NEXT_SESSION_SCAN_MINUTE=0
